@startuml 读者用户_注册登录活动图
title 读者用户注册与登录活动图
skinparam backgroundColor #FFFFFF
skinparam ArrowColor #000000
skinparam defaultFontName Microsoft YaHei
skinparam defaultFontSize 14
skinparam defaultFontStyle plain
skinparam titleFontName Microsoft YaHei
skinparam titleFontSize 18
skinparam titleFontStyle plain
skinparam dpi 150
skinparam activity {
  BackgroundColor #000000
  BorderColor #000000
  FontColor #FFFFFF
  FontSize 14
  FontStyle plain
  MinimumWidth 160
  StartColor #000000
  EndColor #000000
  BarColor #000000
}
start
:进入登录/注册页面;
fork
  :选择学生注册;
  :填写学号、姓名\n性别、专业、密码;
  :系统校验学号是否重复;
  :写入学生用户表;
fork again
  :选择教师注册;
  :填写工号、姓名\n性别、专业、密码;
  :系统校验工号是否重复;
  :写入教师用户表;
fork again
  :输入账号和密码登录;
  :系统匹配学生表\n教师表或管理员表;
  :登录成功后进入系统首页;
end fork
stop
@enduml

