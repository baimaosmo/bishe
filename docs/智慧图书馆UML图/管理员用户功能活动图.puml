@startuml 管理员用户_登录首页活动图
title 管理员用户登录与控制台活动图
skinparam backgroundColor #FFFFFF
skinparam ArrowColor #000000
skinparam defaultFontName Microsoft YaHei
skinparam defaultFontSize 14
skinparam defaultFontStyle plain
skinparam titleFontName Microsoft YaHei
skinparam titleFontSize 18
skinparam titleFontStyle plain
skinparam dpi 150
skinparam activity {
  BackgroundColor #000000
  BorderColor #000000
  FontColor #FFFFFF
  FontSize 14
  FontStyle plain
  MinimumWidth 160
  StartColor #000000
  EndColor #000000
  BarColor #000000
}
start
:进入管理员\n登录页面;
:输入管理员\n账号和密码;
:系统校验\n账号权限;
fork
  :进入控制台看板;
  :查看馆藏总数;
fork again
  :查看今日\n借阅数量;
fork again
  :查看空闲\n座位数量;
fork again
  :查看最近借阅\n和选座动态;
end fork
stop
@enduml

